INSERT INTO dbo.service_items
(
    seed_key,
    category,
    subcategory,
    name,
    unit_type,
    default_price,
    price_note,
    remark,
    sort_order,
    is_active,
    created_at
)
SELECT
    s.seed_key,
    s.category,
    s.subcategory,
    s.name,
    s.unit_type,
    s.default_price,
    s.price_note,
    s.remark,
    s.sort_order,
    1,
    SYSUTCDATETIME()
FROM seed_items s
WHERE NOT EXISTS
(
    SELECT 1
    FROM dbo.service_items existing
    WHERE existing.seed_key = s.seed_key
);
